   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "5a333cbe-2c8e-45af-95e3-12c5ecbe3a05",
   "metadata": {},
   "outputs": [],
   "source": [
    "X = np.array([[1,-1],\n",
    "              [-np.sqrt(3),np.sqrt(3)],\n",
    "              [2,-2]])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "a5ac322f-f235-4959-931a-7abde33005d8",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "array([[ 1.        , -1.        ],\n",
       "       [-1.73205081,  1.73205081],\n",
       "       [ 2.        , -2.        ]])"
      ]
     },
     "execution_count": 3,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "X"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "0a69b122-d0ca-486b-ab06-21024db60f24",
   "metadata": {},
   "outputs": [],
   "source": [
    "_,_,V_t = np.linalg.svd(X)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "f6dc43fe-e51a-4c19-a5b4-545297c7da34",
   "metadata": {},
   "outputs": [],
   "source": [
    "V = V_t.T"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "1b25532c-d52c-4220-9025-58c1292710f5",
   "metadata": {},
   "outputs": [],
   "source": [
    "proj_X_V = X @ V"
   ]
  },
